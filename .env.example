# Nexora Agente — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env com valores reais.

# ── LLM ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=sua-chave-secreta-aqui
AUTH_DEMO_PASSWORD=sua-senha-aqui

# ── Paths ─────────────────────────────────────────────────
WORKSPACE_ROOT=./workspace
GENOME_ROOT=./code_genome
MEMORY_ROOT=./memory

# ── Comportamento ─────────────────────────────────────────
PRESERVE_WORKSPACE=true
OUTPUT_DIR=
DOCKER_ENABLED=True
